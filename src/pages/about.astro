---
export const prerender = true

import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import PageWrapper from '../components/PageWrapper.astro'
import PageHeader from '../components/PageHeader.astro'
import { render } from 'astro:content'
import { getImage } from 'astro:assets'
import { getAboutPage } from '../lib/content'

const about = await getAboutPage()
const { Content } = await render(about)
const title = about.data.title

// Image sizes: Mobile h-36 w-36 (144px), Desktop sm:h-60 sm:w-60 (240px)
// Use 2x size (480px) for retina displays on desktop, which also covers mobile at 2x (288px)
const ABOUT_IMAGE_DISPLAY_SIZE = 240 // Desktop size
const RETINA_SCALE_FACTOR = 2
const ABOUT_IMAGE_OPTIMIZED_SIZE =
  ABOUT_IMAGE_DISPLAY_SIZE * RETINA_SCALE_FACTOR

const imageData = await Promise.all(
  about.data.images.map(async (image) => {
    const optimized = await getImage({
      src: image.src,
      width: ABOUT_IMAGE_OPTIMIZED_SIZE,
      format: 'webp',
    })
    return { src: optimized.src, alt: image.alt }
  })
)

const POSITION_CLASSES = [
  '-top-28 -left-2 sm:-top-48 sm:-left-6 lg:-top-1/3 lg:-left-32', // top-left
  '-top-28 -right-2 sm:-top-48 sm:-right-6 lg:-top-1/3 lg:-right-32', // top-right
  '-bottom-36 -left-2 sm:-bottom-48 sm:-left-6 lg:-bottom-1/3 lg:-left-32', // bottom-left
  '-right-2 -bottom-36 sm:-bottom-48 sm:-right-6 lg:-right-32 lg:-bottom-1/3', // bottom-right
] as const

const FADE_IN_IMAGE_CLASSES = [
  'fade-in-image-3', // top-left
  'fade-in-image-4', // top-right
  'fade-in-image-5', // bottom-left
  'fade-in-image-6', // bottom-right
] as const

const getPositionClasses = (index: number): string => {
  return POSITION_CLASSES[index] || ''
}

const getFadeInClass = (index: number): string => {
  return FADE_IN_IMAGE_CLASSES[index] || ''
}
---

<Layout title="Lucas Silbernagel | About">
  <Header showBackButton={true} />
  <PageWrapper class="p-4">
    <PageHeader
      title="About Me"
      titleClass="fade-in-1 mb-4 text-4xl font-bold text-white md:text-5xl"
    />

    <div class="mx-auto mb-48 mt-36 max-w-6xl">
      <div class="my-16 mt-28 flex justify-center">
        <div
          class="kiosk-tile fade-in-2 relative m-0 max-w-screen-md p-0 sm:p-8"
        >
          {
            imageData.map((image, index) => (
              <div
                class={`${getPositionClasses(index)} ${getFadeInClass(index)} terminal-glow absolute z-10 mx-auto mb-6 flex h-36 w-36 items-center justify-center rounded-full bg-terminal-blue shadow-lg sm:h-60 sm:w-60`}
              >
                <img
                  class="h-full w-full rounded-full object-cover"
                  src={image.src}
                  alt={image.alt}
                />
              </div>
            ))
          }
          <div
            class="space-y-4 px-2 pb-6 pt-6 text-base text-gray-600 sm:px-24 sm:pb-16 sm:text-lg"
          >
            <p class="text-center text-2xl font-bold text-black sm:text-3xl">
              {title}
            </p>
            <Content />
            <p class="text-sm italic">
              Inspired by my love of travel, the design of this website mimics
              the user interface of an airport check-in terminal.
            </p>
          </div>
        </div>
      </div>
    </div>
  </PageWrapper>
</Layout>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .fade-in-1,
    .fade-in-2,
    .fade-in-image-3,
    .fade-in-image-4,
    .fade-in-image-5,
    .fade-in-image-6 {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* Fade-in animations with staggered delays */
  .fade-in-1 {
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
    animation-delay: 0ms;
  }

  .fade-in-2 {
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
    animation-delay: 300ms;
  }

  .fade-in-image-3 {
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
    animation-delay: 600ms;
  }

  .fade-in-image-4 {
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
    animation-delay: 750ms;
  }

  .fade-in-image-5 {
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
    animation-delay: 900ms;
  }

  .fade-in-image-6 {
    opacity: 0;
    animation: fadeIn 0.6s ease-out forwards;
    animation-delay: 1050ms;
  }
</style>
